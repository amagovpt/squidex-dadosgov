{
  "compilerOptions": {
    "target": "es2021",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "module": "commonjs",
    "resolveJsonModule": true,
    "sourceMap": true,
    "allowJs": true,
    "baseUrl": "./src",
    "rootDir": "./src",
    "outDir": "./build",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "paths": {
      "@infrastructure/*": [
        "./infrastructure/*"
      ],
      "@domain/*": [
        "./domain/*"
      ],
      "@useCases/*": [
        "./useCases/*"
      ],
      "@interfaces/*": [
        "./interfaces/*"
      ],
      "@utils/*": [
        "./utils/*"
      ],
      "@lib/*": [
        "./lib/*"
      ],
      "@/*": [
        "./*"
      ]
    }
  },
  "ts-node": {
    "require": [
      "tsconfig-paths/register"
    ],
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.json"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "coverage",
    "**/*.spec.ts"
  ]
}