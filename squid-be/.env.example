# --- General ---
NODE_ENV="production"
PORT=3333
# Comma-separated list of allowed browser origins (CORS). localhost:3000 is
# always allowed outside production. REQUIRED in production (boot fails if empty).
FRONTEND_ORIGIN="https://<FRONTEND_HOST>"
# Number of reverse-proxy hops in front of the gateway (used to derive the real
# client IP for rate limiting). Set to the count of proxies, e.g. 2 for F5 + nginx.
TRUST_PROXY=1

# SECURITY: this disables TLS verification for ALL outbound requests of the
# process, not only Squidex. Prefer a trusted CA cert (e.g. Let's Encrypt) on
# the Squidex side and leave this unset. Only enable for a throwaway
# self-signed setup, and never on the public internet.
# NODE_TLS_REJECT_UNAUTHORIZED='0'

# --- CMS (Squidex) ---
# Base URL WITHOUT the trailing /squidex (the code appends it).
CMS_URL="https://<HOST_IP>"
API_KEY=""
CLIENT_ID="dados-gov:api-dados-gov"
CLIENT_SECRET="<secret-from-squidex>"
APP_NAME="dados-gov"

# --- Gateway tuning ---
# Max GraphQL query nesting depth (DoS guard).
GRAPHQL_MAX_DEPTH=12
# How often (ms) to re-introspect the Squidex schema; 0 disables.
SCHEMA_REFRESH_MS=300000
